# ============================================================
# Telegram Summarizer V2 — Конфигурация окружения
# ============================================================
# Скопируйте этот файл как .env и заполните значения:
#   cp .env.example .env
# ============================================================

# ─── Telegram API credentials ───
# Получить на https://my.telegram.org/ → API development tools
TELEGRAM_API_ID=YOUR_API_ID_HERE
TELEGRAM_API_HASH=YOUR_API_HASH_HERE

# ─── Номер телефона аккаунта для юзербота ───
# Формат: +79001234567 (с кодом страны)
TELEGRAM_PHONE=+79001234567

# ─── Токен управляющего бота ───
# Получить у @BotFather в Telegram
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ─── ID администратора ───
# Ваш личный Telegram User ID (узнать у @userinfobot)
# Только этот пользователь сможет управлять ботом
ADMIN_ID=YOUR_ADMIN_ID_HERE

# ─── Целевой чат для сбора сообщений ───
# @username группы или числовой ID (например: -1001234567890)
TARGET_CHAT=@your_target_chat

# ─── Период автоматического сбора (в часах) ───
# Как часто планировщик будет собирать сообщения в фоне
# Допустимые значения: от 1 до 168
DEFAULT_PERIOD_HOURS=4

# ─── Часовой пояс ───
# Используется для отображения времени в отчетах и логах
# Примеры: Europe/Moscow, Asia/Almaty, UTC
TIMEZONE=Europe/Moscow

# ─── OpenRouter API ───
# Получить ключ на https://openrouter.ai/
# Используется для доступа к бесплатным LLM-моделям
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE
